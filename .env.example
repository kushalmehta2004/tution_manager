# Shared
NODE_ENV=development

# API
PORT=4000
API_BASE_URL=http://localhost:4000
CLIENT_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tuition_manager?schema=public
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
WATI_API_BASE_URL=
WATI_API_TOKEN=
WATI_TEMPLATE_NAME=
FEE_REMINDER_CRON=0 9 * * *
FEE_REMINDER_DEFAULT_TEMPLATE=Reminder: {{student_name}} has pending fee of INR {{amount}} due on {{due_date}}.

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api
